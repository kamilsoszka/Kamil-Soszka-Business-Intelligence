createOrReplace

	model Model
		culture: en-US
		defaultPowerBIDataSourceVersion: powerBI_V3
		sourceQueryCulture: en-US
		dataAccessOptions
			legacyRedirects
			returnErrorValuesAsNull

		table 'Today''s Date'
			lineageTag: 5e1b462d-6c97-4ce6-936d-7cc6b891c4ca

			measure 'MIN Today''s Date' =
					
					MIN ( 'Today''s Date'[Today's Date] )
				formatString: General Date
				lineageTag: 2305cfdc-9c9f-4610-8bb4-6d33573202d5

			measure 'Day number' =
					
					VAR __today =
					    TODAY ()
					VAR Result =
					    DATEDIFF ( DATE ( YEAR ( __today ), 1, 1 ), __today, DAY ) + 1
					RETURN
					    Result
				formatString: 0
				lineageTag: a01fc755-f75e-4192-9e37-1fa99f7c808a

			measure 'Number of days' =
					
					VAR __today =
					    TODAY ()
					VAR __startdate =
					    DATE ( YEAR ( TODAY () ), 1, 1 )
					VAR __enddate =
					    DATE ( YEAR ( TODAY () ), 12, 31 )
					VAR __calendar =
					    CALENDAR ( __startdate, __enddate )
					VAR Result =
					    COUNTROWS ( __calendar )
					RETURN
					    Result
				formatString: 0
				lineageTag: d3533cf0-544b-47ea-a575-147d6cba4f86

			measure Progress =
					
					DIVIDE ( [Day number], [Number of days] )
				formatString: 0.00%;-0.00%;0.00%
				lineageTag: b36e69ae-0282-4512-ba5d-13baf78009af

			column 'Today''s Date'
				dataType: dateTime
				isHidden
				formatString: General Date
				lineageTag: 776302fe-6094-41fd-b573-17ce354e831e
				summarizeBy: none
				sourceColumn: Today's Date

				changedProperty = IsHidden

				annotation SummarizationSetBy = Automatic

			partition 'Today''s Date' = m
				mode: import
				source = DateTime.LocalNow() + #duration(0, 1, 0, 0)

			annotation PBI_NavigationStepName = Navigation

			annotation PBI_ResultType = DateTime

