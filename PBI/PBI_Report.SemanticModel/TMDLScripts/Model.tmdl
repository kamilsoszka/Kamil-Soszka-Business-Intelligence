				source = ```
						let
						    // Step 1: Decompress and parse the Base64-encoded JSON data into a table
						    Source = Table.FromRows(
						        Json.Document(
						            Binary.Decompress(
						                Binary.FromText(
						                    "HcpNCoAgEEDhq8is3fR3gSJaBUFLcSE0kKRTzFjnT91+7xkDy/0hU0RKoKEBqw2s/oiOLyzSVplOR4RBbY4TIUsOXQ0zJeSHvWCmvtIeXQhqfMUTSjkHsPYH", 
						                    BinaryEncoding.Base64
						                ), 
						                Compression.Deflate
						            )
						        ), 
						        // Define the column types after decompression (both as nullable text initially)
						        let _t = ((type nullable text) meta [Serialized.Text = true]) 
						        in type table [Segment = _t, ID_Segment = _t]
						    ),
						
						    // Step 2: Change column types to appropriate types
						    // "Segment" -> text
						    // "ID_Segment" -> 64-bit integer
						    #"Changed Type" = Table.TransformColumnTypes(
						        Source,
						        {{"Segment", type text}, {"ID_Segment", Int64.Type}}
