			column 'Month Number'
				formatString: 0
				lineageTag: fcdf4610-7783-485b-8758-5e4cc02d71fc
				summarizeBy: none
				isNameInferred
				sourceColumn: [Month Number]

				annotation SummarizationSetBy = Automatic

			hierarchy 'Date Hierarchy'
				lineageTag: 876d6db5-92a1-4ab5-a13e-3e41fdda7c54

				level Year
					lineageTag: 38cf797e-5855-4901-a52b-a0fe53d9b56b
					column: Year

				level Quarter
					lineageTag: b026f174-c9a3-46a3-8cc4-231d3cf9ef87
					column: Quarter

				level Month
					lineageTag: 68b2b010-4159-44e4-9244-e2c3da6895a8
					column: Month

				level Date
					lineageTag: 35a68a5c-b8a7-4980-80d8-a28f74358d3e
					column: Date

			partition Date = calculated
				mode: import
				source = ```
						
						VAR __startdate = 
						    // Get the first non-blank Sales[Date] where [Sales] has values
						    FIRSTNONBLANK('Sales'[Date], [Sales])
						
						VAR __enddate = 
						    // Get the last non-blank Sales[Date] where [Sales] has values
						    LASTNONBLANK('Sales'[Date], [Sales])
						
						VAR Result = 
						    // Create a calculated table using CALENDAR function from start to end date
						    ADDCOLUMNS(
						        CALENDAR(__startdate, __enddate),
						        
						        // Add "Year" column
						        "Year", YEAR([Date]),
						
						        // Add formatted Year-Month (e.g., "2023-Jan")
						        "Year Month", FORMAT([Date], "yyyy-mmm"),
						
						        // Add sortable YearMonth format (e.g., "202301")
						        "Year Month Order", FORMAT([Date], "yyyymm"),
						
						        // Add Quarter in format "Q1", "Q2", etc.
						        "Quarter", "Q" & QUARTER([Date]),
						
						        // Add abbreviated month name (e.g., "Jan")
						        "Month", FORMAT([Date], "mmm"),
						
						        // Add numeric month value (1–12)
						        "Month Number", MONTH([Date])
						    )
						
						RETURN
						    Result
						
						```

			annotation PBI_Id = ee0048671a434aa582efe3d201e2497b

		table DAX
			lineageTag: 7d468fd2-829e-4cfd-938c-4fdb43dbdfdd

			measure Sales =
					
					// Calculate the total (sum) of the [Sales] column in the Sales table
					SUM ( 'Sales'[Sales] )
				formatString: \$#,0;(\$#,0);\$#,0
				lineageTag: 95b13e45-b786-46bb-b6eb-b21403f22f25

				annotation PBI_FormatHint = {"currencyCulture":"en-US"}

			measure 'Report Criteria' =
					
					// Create a report criteria string by combining selected values for country, discount segment, and date
					VAR __country =
					    SELECTEDVALUE ( DimCountry[Country] ) // Get the selected country from the DimCountry table
					VAR __discount =
					    SELECTEDVALUE ( DimSegment[Segment] ) // Get the selected segment from the DimSegment table
					VAR __date =
					    SELECTEDVALUE ( 'Date'[Year] ) // Get the selected Year from the Date table
					// Combine the selected values into a single string result
					VAR Result = __country & ", " & __discount & ", " & __date // Concatenate country, discount, and date values
					// Return the combined result
					RETURN
					    "Quick summary" & UNICHAR ( 10 ) & Result
				lineageTag: 12e7dbd0-2f23-4933-ad98-e051096d7ece

			measure COGS =
					
					// Calculate the Total Cost of Goods Sold (COGS)
					SUM ( Sales[COGS] )
					// Sum the values in the 'COGS' column of the 'Sales' table
				formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
				lineageTag: 5fd19a27-f705-4915-a268-5a9f572cc958

			measure Profit =
					
					// Calculate the Profit by subtracting COGS from Sales
					[Sales] - [COGS]
					// Subtract the calculated COGS measure from the Sales measure
				formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
				lineageTag: 4942789f-e5a6-483a-b447-11954cefb813

			measure 'Sales by Product' =
					
					VAR __min =
					    MINX ( ALLSELECTED ( DimProduct[Product] ), [Sales] )
					VAR __max =
					    MAXX ( ALLSELECTED ( DimProduct[Product] ), [Sales] )
					VAR Result =
					    SWITCH ( TRUE (), [Sales] = __max, "Green", [Sales] = __min, "Red", "#061953" )
					RETURN
					    Result
				lineageTag: 61a828f0-9c27-442e-8164-cebfd40a880e

			measure 'COGS by Product' =
					
					VAR __min =
					    MINX ( ALLSELECTED ( DimProduct[Product] ), [COGS] )
					VAR __max =
					    MAXX ( ALLSELECTED ( DimProduct[Product] ), [COGS] )
					VAR Result =
					    SWITCH ( TRUE (), [COGS] = __max, "Red", [COGS] = __min, "Green", "#061953" )
					RETURN
					    Result
				lineageTag: ac9712db-1622-4d86-b4dc-c148dc101a33

			measure 'Profit by Product' =
					
					VAR __min =
					    MINX ( ALLSELECTED ( DimProduct[Product] ), [Profit] )
					VAR __max =
					    MAXX ( ALLSELECTED ( DimProduct[Product] ), [Profit] )
					VAR Result =
					    SWITCH (
					        TRUE (),
					        [Profit] = __max, "Green",
					        [Profit] = __min, "Red",
					        "#061953"
					    )
					RETURN
					    Result
				lineageTag: e5ed3103-0105-49a6-b613-d1afbcd25b44

			measure 'COGS by Product (txt)' =
					
					VAR __min =
					    MINX ( ALLSELECTED ( DimProduct[Product] ), [COGS] )
					VAR __max =
					    MAXX ( ALLSELECTED ( DimProduct[Product] ), [COGS] )
					VAR Result =
					    SWITCH (
					        TRUE (),
					        [COGS] = __max, "#605E5C",
					        [COGS] = __min, "#605E5C",
					        "#FFFFFF00"
					    )
					RETURN
					    Result
				lineageTag: 68fd26aa-3c57-4cd8-8960-41df0ab46994

			measure 'Sales by Product (txt)' =
					
					VAR __min =
					    MINX ( ALLSELECTED ( DimProduct[Product] ), [Sales] )
					VAR __max =
					    MAXX ( ALLSELECTED ( DimProduct[Product] ), [Sales] )
					VAR Result =
					    SWITCH (
					        TRUE (),
					        [Sales] = __max, "#605E5C",
					        [Sales] = __min, "#605E5C",
