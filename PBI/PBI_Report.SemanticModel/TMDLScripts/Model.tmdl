			column Sales
				formatString: 0
				lineageTag: 92c51778-8805-458f-af2c-0446c67d94aa
				summarizeBy: sum
				isNameInferred
				sourceColumn: [Sales]

				annotation SummarizationSetBy = Automatic

			column COGS
				formatString: 0
				lineageTag: 6adc2206-6c95-4412-8741-f67af2fff8c4
				summarizeBy: sum
				isNameInferred
				sourceColumn: [COGS]

				annotation SummarizationSetBy = Automatic

			partition Sales = calculated
				mode: import
				source = ```
						
						// Generate a sample Sales table with random data
						VAR Result = 
						    ADDCOLUMNS(
						        // Generate a base table with 50000 rows (values from 1 to 50000)
						        GENERATESERIES(1, 50000),
						
						        // Add a random date between today and 700 days ago
						        "Date", TODAY() - RANDBETWEEN(1, 700),
						
						        // Add a random segment ID (values between 1 and 5)
						        "ID_Segment", RANDBETWEEN(1, 5),
						
						        // Add a random country ID (values between 1 and 5)
						        "ID_Country", RANDBETWEEN(1, 5),
						
						        // Add a random product ID (values between 1 and 6)
						        "ID_Product", RANDBETWEEN(1, 6)
						    )
						
						// Add Sales and COGS values to the result table and return it
						RETURN
						    ADDCOLUMNS(
						        Result,
						
						        // Add a random Sales value between 10 and 45
						        "Sales", RANDBETWEEN(100, 450),
						
						        // Add a random COGS (Cost of Goods Sold) value between 5 and 15
						        "COGS", RANDBETWEEN(50, 150)
						    )
						
						```

			annotation PBI_Id = d283c66d4c904141b1f98c5d9e64465d

