					    )
					RETURN
					    Result
				lineageTag: 52138b28-7416-4aee-a771-bccebab40ee0

			measure 'Profit by Product (txt)' =
					
					VAR __min =
					    MINX ( ALLSELECTED ( DimProduct[Product] ), [Profit] )
