	measure 'Sales Average (yyyy-mm)' =
			
			CALCULATE (
			    AVERAGEX ( ALLSELECTED ( 'Date'[Year Month] ), [Sales] ),
			    ALLSELECTED ()
			)
		lineageTag: c9c9c1bd-77df-4f3e-a28b-338280e7c73f

