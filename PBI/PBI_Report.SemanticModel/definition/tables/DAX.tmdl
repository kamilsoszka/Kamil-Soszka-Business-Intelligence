	measure 'Sales Average' =
			
			CALCULATE ( AVERAGEX ( DimProduct, [Sales] ), ALLSELECTED () )
		lineageTag: 48d14fe7-07ee-41e5-95ef-13339798e355

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'COGS Average' =
			
